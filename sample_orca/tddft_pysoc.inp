! B3LYP D3BJ RIJCOSX CPCM(Acetonitrile) AutoAux 

# --- Print Controls for External Parsing ---
# These keywords force ORCA to print the specific matrices to the .out file.
%output
    Print[ P_Basis ] 2     # Prints detailed AO Basis Set block and subshell mapping
    Print[ P_Overlap ] 1   # Prints the complete AO Overlap Matrix
    Print[ P_MOs ] 1       # Prints the Alpha MO Coefficients and MO Energies
end

# --- TDDFT Settings ---
%tddft
    NRoots 5               # Computes 5 Singlet roots
    Triplets true          # Computes 5 Triplet roots 
    TDA false              # Uses full TDDFT (RPA) rather than the Tamm-Dancoff approximation (TDA)
    PrintLevel 3           # Forces printing of ALL Configuration Interaction (CI) coefficients
end

# --- Basis Set Definition ---
%basis
    NewGTO   Ru "LANL2DZ" end
    NewECP   Ru "LANL2" end
    NewGTO   C  "6-311G(d)" end
    NewGTO   H  "6-311G(d)" end
    NewGTO   N  "6-311G(d)" end
    NewGTO   S  "6-311G(d)" end
end

%maxcore 3000
%pal nprocs 10 end

# Using the optimized geometry from your previous step. 
# Charge 2, Multiplicity 1 (Closed-shell Singlet)
